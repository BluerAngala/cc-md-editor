{
  "name": "cc-md-editor",
  "type": "module",
  "version": "2.1.0",
  "private": false,
  "description": "CC Markdown 编辑器 — 基于 doocs/md 二次开发的微信 Markdown 编辑器，深度优化 AI 辅助写作、公众号排版兼容性与主题系统",
  "homepage": "https://github.com/BluerAngala/cc-md-editor",
  "repository": {
    "type": "git",
    "url": "https://github.com/BluerAngala/cc-md-editor"
  },
  "bugs": {
    "url": "https://github.com/BluerAngala/cc-md-editor/issues"
  },
  "engines": {
    "node": ">=22.22.2"
  },
  "scripts": {
    "start": "pnpm web dev",
    "web": "pnpm --filter @md/web",
    "vscode": "pnpm --prefix ./apps/vscode",
    "vscode:test": "pnpm --prefix ./apps/vscode test",
    "mcp": "pnpm --filter @md/mcp-server",
    "api": "pnpm --filter @md/api",
    "cli": "pnpm --filter @doocs/md-cli",
    "build:cli": "pnpm web build && npx shx rm -rf packages/md-cli/dist && npx shx rm -rf dist/**/*.map && npx shx cp -r apps/web/dist packages/md-cli/ && cd packages/md-cli && npm pack",
    "release:cli": "node ./scripts/release.js",
    "lint": "eslint . --fix",
    "type-check": "pnpm type-check:web && pnpm type-check:packages",
    "type-check:web": "pnpm --filter @md/web exec vue-tsc --noEmit",
    "type-check:packages": "pnpm --filter @md/core --filter @md/shared --filter @md/api run type-check",
    "test": "pnpm --filter @md/core test && pnpm --filter @md/web test",
    "postinstall": "simple-git-hooks",
    "inspector": "pnpx node-modules-inspector",
    "utools:package": "node ./scripts/package-utools.mjs",
    "link-claude-skills": "node ./scripts/link-claude-skills.mjs"
  },
  "dependencies": {
    "@codemirror/state": "6.7.0",
    "@codemirror/view": "6.43.3"
  },
  "devDependencies": {
    "@antfu/eslint-config": "9.1.0",
    "@types/node": "^26.0.1",
    "archiver": "^8.0.0",
    "eslint": "^10.5.0",
    "eslint-plugin-format": "^2.0.1",
    "prettier": "2.8.8",
    "shx": "^0.4.0",
    "simple-git-hooks": "^2.13.1",
    "typescript": "~6.0.3"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.{js,ts,vue,jsx,tsx,json,yaml,toml,html,css,less,scss}": "eslint --fix"
  }
}
